# GitLab Webhook Settings
GITLAB_WEBHOOK_SECRET=your_secret_here
GITLAB_WEBHOOK_SIGNING_TOKEN=your_signing_token_here

# GitLab API Settings
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_API_TOKEN=your_gitlab_token_here

# Huly Settings
HULY_URL=https://huly.app
HULY_WORKSPACE=your_workspace_id
HULY_EMAIL=your_email@example.com
HULY_PASSWORD=your_password_here
HULY_PROJECT_IDENTIFIER=HULY